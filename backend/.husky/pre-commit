#!/usr/bin/env sh

echo "🔍 Executando testes unitários antes do commit..."

# Mudar para diretório backend
cd backend

# Executar testes unitários
npm run test:unit -- --bail --passWithNoTests

# Se testes falharem, abortar commit
if [ $? -ne 0 ]; then
  echo "❌ Testes falharam! Corrija os erros antes de fazer commit."
  exit 1
fi

echo "✅ Testes passaram! Commit permitido."