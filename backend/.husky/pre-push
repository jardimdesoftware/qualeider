#!/usr/bin/env sh

echo "Executando todos os testes antes do push..."

# Mudar para diretório backend
cd backend

# Executar testes unitários
npm run test:unit

if [ $? -ne 0 ]; then
  echo "Testes unitários falharam! Push bloqueado."
  exit 1
fi

# Executar testes E2E apenas se o banco de dados de teste estiver acessível
# Para forçar E2E: RUN_E2E=true git push
# Para pular E2E:  RUN_E2E=false git push  (padrão quando banco não está disponível)
echo "Verificando disponibilidade do banco de dados de teste..."

DB_AVAILABLE=$(node -e "
const net = require('net');
const sock = new net.Socket();
sock.setTimeout(2000);
sock.on('connect', () => { sock.destroy(); process.exit(0); });
sock.on('error', () => process.exit(1));
sock.on('timeout', () => process.exit(1));
sock.connect(5432, '127.0.0.1');
" 2>/dev/null; echo $?)

if [ "$RUN_E2E" = "true" ] || [ "$DB_AVAILABLE" = "0" ]; then
  echo "Executando testes E2E..."
  npm run test:e2e

  if [ $? -ne 0 ]; then
    echo "Testes E2E falharam! Push bloqueado."
    exit 1
  fi
else
  echo "Banco de dados de teste (127.0.0.1:5432) nao acessivel — testes E2E pulados."
  echo "Para rodar E2E antes do push: RUN_E2E=true git push"
fi

echo "Todos os testes passaram! Push permitido."
