#!/usr/bin/env sh

echo "Executando testes unitarios antes do push..."

# Mudar para diretorio backend
cd backend

# Executar testes unitarios
npm run test:unit

if [ $? -ne 0 ]; then
  echo "Testes unitarios falharam! Push bloqueado."
  exit 1
fi

# Testes E2E requerem banco qualeider_test acessivel localmente.
# Sao pulados por padrao para nao bloquear pushes em ambientes de desenvolvimento.
# Para rodar E2E: RUN_E2E=true git push
if [ "$RUN_E2E" = "true" ]; then
  echo "Executando testes E2E..."
  npm run test:e2e

  if [ $? -ne 0 ]; then
    echo "Testes E2E falharam! Push bloqueado."
    exit 1
  fi
else
  echo "Testes E2E pulados (use RUN_E2E=true git push para incluir E2E)."
fi

echo "Testes passaram! Push permitido."
