generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum UserType {
  Pecuarista
  Cooperativa
  Associacao
  Outro
}

enum UserCategory {
  Fisica
  Juridica
}

enum AnimalType {
  Vaca
  Cabra
  Ovelha
  Bufala
  Outro
}

enum MilkingPlace {
  Aberto
  Curral
  Ambos
}

enum CoverageArea {
  Municipal
  Regional
  Estadual
}

enum Status {
  Active
  Inactive
}

model Association {
  id                    Int              @id @default(autoincrement())
  name                  String           
  tradeName             String?          
  cnpj                  String           @unique 
  stateRegistration     String?          
  email                 String           @unique
  password              String           
  landlinePhone         String          
  mobilePhone           String?          
  website               String?          
  zipCode               String?          
  state                 String           
  city                  String           
  street                String?          
  number                String?          
  complement            String?          
  neighborhood          String?          
  foundationDate        DateTime?        
  numberOfMembers       Int?             
  coverageArea          CoverageArea           
  presidentName         String?          
  presidentCpf          String?          
  presidentEmail        String?          
  presidentPhone        String?          
  status                Status           @default(Active)
  users                 User[]
  notifications         Notification[]
  invites               Invite[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  @@index([city, state])
  @@index([status])
  @@index([cnpj])
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id                    Int              @id @default(autoincrement())
  associationId         Int?             
  association           Association?     @relation(fields: [associationId], references: [id])
  name                  String
  email                 String           @unique
  password              String
  userType              UserType?
  userCategory          UserCategory 
  document              String?          @unique // CPF ou CNPJ
  city                  String           
  state                 String 
  role                  UserRole         @default(ADMIN)
  status                Status           @default(Active)
  resetToken            String?
  resetTokenExpiry      DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  lastLogin             DateTime?
  animals               Animal[]
  dailyCollections      DailyCollection[]
  invites               Invite[]
  receivedNotifications NotificationRecipient[]
  @@index([city, state, status])
  @@index([associationId, status])
}

model Breed {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  animals     Animal[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model AnimalSpecies {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  animals     Animal[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("animal_species")
  @@index([name])
}

model Animal {
  id                    Int              @id @default(autoincrement())
  tagNumber             String?          // numero de identificacao/brinco
  name                  String?
  animalType            AnimalType?
  breed                 String?
  age                   Int
  userId                Int
  breedId               Int?
  animalSpeciesId       Int?
  animalSpecies         AnimalSpecies?   @relation(fields: [animalSpeciesId], references: [id])
  status                Status           @default(Active)
  user                  User             @relation(fields: [userId], references: [id])
  breedRelation         Breed?           @relation(fields: [breedId], references: [id])

  // Parentesco - Mae
  motherId              Int?
  mother                Animal?          @relation("AnimalMother", fields: [motherId], references: [id])
  childrenAsMother      Animal[]         @relation("AnimalMother")
  motherCode            String?          // numero da mae quando nao cadastrada no sistema

  // Parentesco - Pai/Reprodutor
  fatherId              Int?
  father                Animal?          @relation("AnimalFather", fields: [fatherId], references: [id])
  childrenAsFather      Animal[]         @relation("AnimalFather")
  fatherCode            String?          // numero/codigo do pai quando nao cadastrado

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  dailyCollectionItems  DailyCollectionItem[]

  @@unique([userId, tagNumber])
  @@index([userId, tagNumber])
  @@index([motherId])
  @@index([fatherId])
}

model DailyCollection {
  id                    Int              @id @default(autoincrement())
  quantity              Float            
  collectionDate        DateTime         @default(now()) 
  userId                Int              
  user                  User             @relation(fields: [userId], references: [id])
  numAnimals            Int              
  numOrdens             Int              
  rationProvided        Boolean          
  numLactation          Int              
  milkingPlace          MilkingPlace     
  technicalAssistance   Boolean          
  status                Status           @default(Active)
  items                 DailyCollectionItem[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  
  @@index([userId, status])
  @@index([collectionDate])
}

model DailyCollectionItem {
  id                Int             @id @default(autoincrement())
  dailyCollectionId Int
  dailyCollection   DailyCollection @relation(fields: [dailyCollectionId], references: [id], onDelete: Cascade)
  animalId          Int
  animal            Animal          @relation(fields: [animalId], references: [id])
  quantity          Float
  cmtResult         CmtResult?      // resultado do teste da caneca (opcional)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([dailyCollectionId])
  @@index([animalId])
  @@index([dailyCollectionId, animalId])
}

enum CmtResult {
  Normal
  Suspeito
  Positivo
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELED
}

model Invite {
  id                    Int              @id @default(autoincrement())
  associationId         Int
  association           Association      @relation(fields: [associationId], references: [id])
  userId                Int
  user                  User             @relation(fields: [userId], references: [id])
  token                 String           @unique @default(uuid())
  status                InviteStatus     @default(PENDING)
  message               String?
  customMessage         String?
  sentAt                DateTime         @default(now())
  expiresAt             DateTime
  respondedAt           DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([associationId])
  @@index([userId])
  @@index([status])
  @@index([token])
  @@index([expiresAt])
}

model Notification {
  id                    Int              @id @default(autoincrement())
  associationId         Int
  association           Association      @relation(fields: [associationId], references: [id])
  subject               String
  message               String
  metadata              String?          // JSON string
  recipients            NotificationRecipient[]
  createdAt             DateTime         @default(now())

  @@index([associationId])
  @@index([createdAt])
}

model NotificationRecipient {
  id              Int          @id @default(autoincrement())
  notificationId  Int
  notification    Notification @relation(fields: [notificationId], references: [id])
  userId          Int
  user            User         @relation(fields: [userId], references: [id])
  read            Boolean      @default(false)
  readAt          DateTime?
  createdAt       DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([read])
  @@index([userId, read, createdAt])
}

model FailedEmail {
  id          String   @id @default(uuid())
  payload     Json     
  errorReason String   
  retryCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("failed_emails")
}
