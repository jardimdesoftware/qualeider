<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Notificação - QualeiDer</title>
</head>
<body style="margin: 0; padding: 0; background-color: #fdfbf7; font-family: 'Roboto', Arial, sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #fdfbf7; padding: 40px 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); border: 1px solid #e2e8f0;">
                    
                    <tr>
                        <td style="background-color: #1e3a29; padding: 20px 30px; border-bottom: 4px solid #d97706;">
                            <table width="100%">
                                <tr>
                                    <td align="left">
                                        <span style="color: #ffffff; font-family: 'Roboto Slab', Georgia, serif; font-size: 20px; font-weight: bold;">QualeiDer</span>
                                    </td>
                                    <td align="right">
                                        <span style="color: #4ade80; font-size: 12px; font-weight: bold; text-transform: uppercase;">Notificação</span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 40px 30px;">
                            <p style="font-size: 14px; color: #888888; text-transform: uppercase; margin: 0 0 10px 0; letter-spacing: 1px;">
                                Olá, {{userName}}
                            </p>
                            
                            <h2 style="color: #1e3a29; font-family: 'Roboto Slab', Georgia, serif; font-size: 24px; margin-top: 0; margin-bottom: 25px;">
                                {{subject}}
                            </h2>

                            <div style="background-color: #f1f5f9; border-left: 5px solid #1e3a29; padding: 20px; border-radius: 0 4px 4px 0;">
                                <p style="font-size: 16px; color: #334155; line-height: 1.6; margin: 0; white-space: pre-wrap;">{{message}}</p>
                            </div>

                            {{#if metadata}}
                            <div style="margin-top: 30px;">
                                <table width="100%" cellpadding="10" cellspacing="0" style="background-color: #fff7ed; border-radius: 6px; border: 1px solid #fed7aa;">
                                    <tr>
                                        <td>
                                            <p style="font-size: 13px; color: #9a3412; margin: 0;">
                                                <strong>Detalhes:</strong> 
                                                {{#if metadata.associationName}}Associação: {{metadata.associationName}} • {{/if}}
                                                {{#if metadata.category}}Categoria: {{metadata.category}}{{/if}}
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            {{/if}}
                            
                            <div style="margin-top: 30px; text-align: center;">
                                <a href="${process.env.FRONTEND_URL || 'http://localhost:3000'}/dashboardUser/notifications" style="display: inline-block; background-color: #1e3a29; color: #ffffff; text-decoration: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; font-size: 14px;">Ver no Sistema</a>
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td style="background-color: #f8fafc; padding: 15px; text-align: center; border-top: 1px solid #e2e8f0;">
                            <p style="margin: 0; font-size: 11px; color: #94a3b8;">
                                Mensagem enviada automaticamente pelo sistema QualeiDer.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
