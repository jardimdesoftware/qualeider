# =============================================================================
# backend/.env.example — Qualeider Backend
# =============================================================================
# Variáveis de ambiente usadas quando o backend roda diretamente no host
# (desenvolvimento com hot-reload: npm run start:dev).
#
# Copie para backend/.env antes de rodar:
#   cp backend/.env.example backend/.env
#
# Com docker-compose.dev.yml rodando, o PostgreSQL fica em localhost:5432.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qualeider?schema=public"

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET="dev-secret-key-nao-usar-em-producao"
JWT_EXPIRATION="24h"

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
# Em desenvolvimento, use o Ethereal (https://ethereal.email) para capturar emails
# sem enviar de verdade, ou deixe em branco. Sem SMTP configurado, login e troca de
# senha continuam funcionando; convites e notificações falham silenciosamente
# (só notificações caem na tabela failed_emails); "esqueci minha senha" retorna
# erro na requisição mesmo salvando o token no banco. Detalhes completos em
# README.md > "Comportamento de e-mail (SMTP) em desenvolvimento".
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@qualeider.com"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# CORS — origens permitidas (lista separada por vírgula, sem espaços).
# O código (src/presentation/main.ts) já suporta múltiplas origens — é só
# listar todas as que o navegador vai usar para acessar o frontend.
#
# Em desenvolvimento, o frontend Next.js roda em localhost:3001. Se você
# também acessa o app de outra máquina/VM na mesma rede, inclua localhost,
# 127.0.0.1 e o IP real (troque pelo IP da sua rede):
CORS_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"
# CORS_ORIGINS="http://localhost:3001,http://127.0.0.1:3001,http://192.168.10.85:3001"

# Em produção, use o(s) domínio(s) real(is) — nunca "*". A API usa
# credentials: true (JWT/cookies), então liberar qualquer origem é inseguro.

# -----------------------------------------------------------------------------
# Redis Cache (opcional em desenvolvimento)
# -----------------------------------------------------------------------------
# O backend usa in-memory cache automaticamente quando NODE_ENV != production.
# Configure abaixo apenas se quiser testar o Redis localmente.
# Com docker-compose.dev.yml, o Redis fica disponível em localhost:6379.
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
