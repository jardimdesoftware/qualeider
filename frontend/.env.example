# URL base da API consumida pelo frontend (deve incluir o prefixo /api).
#
# O backend roda em desenvolvimento (npm run start:dev) na porta 3000,
# não na 8080 — confira backend/.env.example (PORT=3000) e
# backend/src/presentation/main.ts (app.setGlobalPrefix('api')).
#
# Cenário 1: frontend e backend no mesmo host (fluxo padrão do README)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Cenário 2: backend rodando em outra máquina/VM ou acessado pela rede local
# (troque pelo IP real da máquina que roda o backend)
# NEXT_PUBLIC_API_URL=http://192.168.10.85:3000/api

# Cenário 3: acesso via nginx/proxy reverso (docker-compose.local.yml),
# que já expõe o backend sob o mesmo host/porta do frontend em /api
# NEXT_PUBLIC_API_URL=/api

# Sentry Error Tracking (optional - get DSN from https://sentry.io)
# NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@sentry.io/your-project-id
