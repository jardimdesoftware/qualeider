# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qualeider

# Backend Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3001

# Email Configuration (SMTP)
# Required in PRODUCTION (invites, password reset)
# Optional in DEVELOPMENT (emails will be logged to FailedEmail table)
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=noreply@qualeider.com

# Frontend Configuration
NEXT_PUBLIC_API_URL=/api
