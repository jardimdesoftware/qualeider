# =============================================================================
# .env.example — Qualeider
# =============================================================================
# Variáveis de ambiente do projeto.
# Copie para .env e preencha os valores antes de rodar qualquer compose:
#   cp .env.example .env
#
# ATENÇÃO: nunca comite o arquivo .env com valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qualeider

# Porta exposta no host (apenas para docker-compose.dev.yml)
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Backend — API NestJS
# -----------------------------------------------------------------------------
# Chave secreta para assinar tokens JWT. Use um valor longo e aleatório em prod.
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# Porta que o backend expõe no host (docker-compose.yml)
BACKEND_PORT=3000

# Origens permitidas no CORS (separadas por vírgula)
# Em produção, coloque o domínio real: https://seudominio.com.br
CORS_ORIGINS=http://localhost:3001

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
# Necessário para envio de convites e redefinição de senha.
# Em desenvolvimento, se não configurado, os emails falham silenciosamente
# e ficam registrados na tabela FailedEmail do banco.
#
# Gmail: use uma App Password (não a senha da conta)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=noreply@qualeider.com

# -----------------------------------------------------------------------------
# Redis — Cache distribuído
# -----------------------------------------------------------------------------
# O Redis só é ativado pelo backend quando NODE_ENV=production.
# Em desenvolvimento, o backend usa in-memory cache automaticamente.
REDIS_PASSWORD=qualeider_redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Frontend — Next.js
# -----------------------------------------------------------------------------
# URL base da API consumida pelo frontend (sempre com o prefixo /api).
# Esta variável é lida em build-time do frontend (Next.js), então o compose
# usada deve refletir de onde o NAVEGADOR do usuário vai acessar a API —
# não o nome do serviço interno do Docker (ex.: não use http://backend:3000).
#
# - docker-compose.yml (prod sem nginx, mesmo host do navegador):
#     NEXT_PUBLIC_API_URL=http://localhost:3000/api
# - docker-compose.yml em servidor remoto/VM/rede local (troque pelo IP/domínio real):
#     NEXT_PUBLIC_API_URL=http://192.168.10.85:3000/api
# - docker-compose.local.yml / docker-compose.prod.yml (com nginx como proxy):
#     NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Porta que o frontend expõe no host (docker-compose.yml)
FRONTEND_PORT=3001

# -----------------------------------------------------------------------------
# Produção via GHCR — docker-compose.prod.yml
# -----------------------------------------------------------------------------
# Owner das imagens no GHCR (organização ou usuário GitHub)
# Imagens publicadas em: ghcr.io/<GHCR_OWNER>/qualeider-backend e qualeider-frontend
GHCR_OWNER=jardimdesoftware

# Tags das imagens — "latest" ou versão específica (ex: 1.2.0)
BACKEND_TAG=latest
FRONTEND_TAG=latest

# Porta do Nginx quando usar docker-compose.prod.yml ou docker-compose.local.yml
NGINX_HTTP_PORT=80
